# Build the SPA, then serve the static bundle with nginx (which also reverse-proxies /api -> the
# api service, so the browser uses same-origin URLs and SSE streams through untouched).
FROM node:20-alpine AS build
WORKDIR /app
COPY gui/package.json ./
RUN npm install
COPY gui/ ./
RUN npm run build

FROM nginx:1.27-alpine
RUN rm -f /etc/nginx/conf.d/default.conf
COPY docker/nginx.conf /etc/nginx/conf.d/cloq.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
