# Rocq + coq-lsp + petanque + CoqHammer, with Picinae/Cloq prebuilt.
# Base on the community Coq image; pin a version that matches your coq-lsp release.
FROM coqorg/coq:8.20

USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential git rlwrap z3 \
    && rm -rf /var/lib/apt/lists/*
USER coq

# coq-lsp ships petanque (pet-server); lwt+logs are required for the pet-server
# executable to be built. CoqHammer is the automation net.
RUN opam update && opam install -y lwt logs \
    && opam install -y coq-lsp coq-hammer coq-hammer-tactics \
    && opam clean -a -c

# Build the vendored Picinae/Cloq in three layers: core -> timing -> examples.
# No `|| true`: if any layer fails to compile, the image build must fail loudly.
WORKDIR /work
COPY --chown=coq:coq vendor/picinae /work/vendor/picinae
RUN eval $(opam env) \
 && make -C /work/vendor/picinae \
 && make -C /work/vendor/picinae/timing \
 && cd /work/vendor/picinae/timing/examples/data_structures/array/find_in_array \
 && coqc -R /work/vendor/picinae Picinae array.v \
 && cd /work/vendor/picinae/timing/examples \
 && coqc -R /work/vendor/picinae Picinae \
      -I /work/vendor/picinae/timing/riscv \
      -I /work/vendor/picinae/timing/examples/data_structures/array/find_in_array \
      -w -notation-overridden -w -deprecated-since-8.20 -w -overriding-logical-loadpath \
      riscv_addloop_timing_proof.v

COPY --chown=coq:coq proofs /work/proofs
EXPOSE 8765
# Launch petanque so pytanque can connect from the agent container. --root makes
# coq-lsp pick up /work/proofs/_CoqProject (the -R Picinae load path); without it
# pet-server only sees the stdlib, so `Require Import Picinae_riscv` silently fails
# and every theorem statement referencing a Picinae symbol (startof, exits, ...)
# can't be elaborated by `start`.
CMD ["bash", "-lc", "eval $(opam env) && pet-server --address 0.0.0.0 --port 8765 --root /work/proofs"]
