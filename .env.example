# cloq-agent secrets / model overrides. Copy to .env (which is git-ignored) and fill in.
#   cp .env.example .env
#
# Required for the `api` (cloud) profile; also used as the escalation key in the `local` profile.
CLOQ_API_KEY=sk-your-cloud-api-key

# Optional: override the cloud model + endpoint (any OpenAI-compatible API). Defaults target
# Anthropic's OpenAI-compatible endpoint (see config/api.yaml).
CLOQ_MODEL_NAME=claude-opus-4-8
CLOQ_MODEL_BASE_URL=https://api.anthropic.com/v1
