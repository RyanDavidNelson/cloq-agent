# Python agent: orchestrator, RAG, eval. Talks to pet-server (rocq) and a model server.
FROM python:3.11-slim

RUN pip install --no-cache-dir uv
WORKDIR /app
COPY pyproject.toml README.md ./
COPY src ./src
COPY eval ./eval
COPY config ./config
RUN uv pip install --system -e ".[rag]"

ENV CLOQ_PETANQUE_HOST=rocq
ENV CLOQ_MODEL_BASE_URL=http://host.docker.internal:11434/v1
ENTRYPOINT ["cloq-agent"]
CMD ["--help"]
